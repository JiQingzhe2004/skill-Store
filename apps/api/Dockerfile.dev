FROM node:20-alpine

RUN npm install -g pnpm@10.5.2

WORKDIR /app

# Copy workspace manifests
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY apps/api/package.json ./apps/api/
COPY packages/shared/package.json ./packages/shared/

# Install all deps (including devDeps)
RUN pnpm install --frozen-lockfile

# Copy source (will be overridden by volume mounts in dev)
COPY apps/api ./apps/api
COPY packages/shared ./packages/shared

# Generate Prisma client (bypass prisma-runner.mjs which requires root .env)
RUN cd apps/api && DATABASE_URL=mysql://placeholder:placeholder@localhost:3306/placeholder npx prisma generate --schema prisma/schema.prisma

EXPOSE 3001

CMD ["sh", "-c", "pnpm install --frozen-lockfile && cd apps/api && npx prisma migrate dev --schema=prisma/schema.prisma --skip-seed && cd /app && pnpm --filter @skill-store/api dev"]
