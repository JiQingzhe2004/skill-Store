# ─── 应用 ───────────────────────────────────────────────
# 前端访问地址（用于邮件中的链接等）
APP_URL=http://localhost:3000

# ─── 数据库 ──────────────────────────────────────────────
# 主数据库连接（MySQL）
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/skill_store

# Prisma migrate 时使用的影子数据库（与主库同账号，不同库名）
SHADOW_DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/skill_store_shadow

# ─── JWT ─────────────────────────────────────────────────
# Access Token 签名密钥（建议 64 位随机字符串）
JWT_ACCESS_SECRET=replace-with-a-long-random-string

# Refresh Token 签名密钥（必须与 ACCESS_SECRET 不同）
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# ─── 邮件 ────────────────────────────────────────────────
# SMTP 服务器地址（生产环境推荐 SendGrid / Resend / Mailgun）
SMTP_HOST=smtp.example.com

# SMTP 端口（TLS: 587, SSL: 465, 开发 Mailpit: 1025）
SMTP_PORT=587

# SMTP 认证用户名
SMTP_USER=your-smtp-username

# SMTP 认证密码
SMTP_PASS=your-smtp-password

# 发件人名称和地址
SMTP_FROM=Skill Store <no-reply@your-domain.com>

# ─── 管理员初始化 ─────────────────────────────────────────
# 首次部署时，已登录用户调用 POST /api/admin/setup { "secret": "..." } 可将自己设为管理员
# 设置完成后建议改为随机字符串防止滥用
ADMIN_SETUP_SECRET=change-me-before-deploy
