generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id              String      @id @default(cuid()) @db.VarChar(191)
  email           String      @unique @db.VarChar(191)
  username        String      @db.VarChar(32)
  passwordHash    String      @map("password_hash") @db.VarChar(255)
  role            UserRole    @default(USER)
  avatar          String?     @db.LongText
  bio             String?     @db.VarChar(200)
  isBanned        Boolean     @default(false) @map("is_banned")
  bannedUntil     DateTime?   @map("banned_until")
  banReason       String?     @db.VarChar(256) @map("ban_reason")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  lastLoginAt     DateTime?   @map("last_login_at")
  skillComments   SkillComment[]
  skills          Skill[]
  installedSkills UserInstalledSkill[]
  stars           SkillStar[]
  likes           SkillLike[]
  apiClients      ApiClient[]

  @@map("users")
}

enum SkillVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum SkillStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
  REJECTED
}

model Skill {
  id             String          @id @default(cuid()) @db.VarChar(191)
  slug           String          @unique @db.VarChar(128)
  name           String          @db.VarChar(128)
  description    String          @db.VarChar(512)
  tags           String          @default("") @db.VarChar(512)
  visibility     SkillVisibility @default(PUBLIC)
  status         SkillStatus     @default(DRAFT)
  latestVersion  String?         @map("latest_version") @db.VarChar(32)
  downloadCount  Int             @default(0) @map("download_count")
  starCount      Int             @default(0) @map("star_count")
  likeCount      Int             @default(0) @map("like_count")
  authorId       String          @map("author_id") @db.VarChar(191)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions       SkillVersion[]
  installs       UserInstalledSkill[]
  stars          SkillStar[]
  likes          SkillLike[]
  comments       SkillComment[]

  @@index([authorId])
  @@index([status, visibility])
  @@map("skills")
}

model SkillVersion {
  id          String   @id @default(cuid()) @db.VarChar(191)
  skillId     String   @map("skill_id") @db.VarChar(191)
  version     String   @db.VarChar(32)
  content     String   @db.LongText
  changelog   String?  @db.Text
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  skill       Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  installs    UserInstalledSkill[]
  files       SkillVersionFile[]

  @@unique([skillId, version])
  @@index([skillId])
  @@map("skill_versions")
}

model SkillComment {
  id        String        @id @default(cuid()) @db.VarChar(191)
  skillId   String        @map("skill_id") @db.VarChar(191)
  userId    String        @map("user_id") @db.VarChar(191)
  content   String        @db.Text
  parentId  String?       @map("parent_id") @db.VarChar(191)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  skill     Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade, map: "skill_comments_user_fk")
  parent    SkillComment? @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   SkillComment[] @relation("replies")

  @@index([skillId])
  @@index([userId])
  @@index([parentId])
  @@map("skill_comments")
}

model SkillVersionFile {
  id         String   @id @default(cuid()) @db.VarChar(191)
  versionId  String   @map("version_id") @db.VarChar(191)
  path       String   @db.VarChar(512)
  content    String   @db.LongText
  encoding   String   @default("utf8") @db.VarChar(16)
  size       Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  version    SkillVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, path])
  @@index([versionId])
  @@map("skill_version_files")
}

model UserInstalledSkill {
  id               String       @id @default(cuid()) @db.VarChar(191)
  userId           String       @map("user_id") @db.VarChar(191)
  skillId          String       @map("skill_id") @db.VarChar(191)
  installedVersion String       @map("installed_version") @db.VarChar(32)
  trackLatest      Boolean      @default(true) @map("track_latest")
  installedAt      DateTime     @default(now()) @map("installed_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill            Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  versionRef       SkillVersion @relation(fields: [skillId, installedVersion], references: [skillId, version])

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@map("user_installed_skills")
}

model SkillStar {
  id        String   @id @default(cuid()) @db.VarChar(191)
  userId    String   @map("user_id") @db.VarChar(191)
  skillId   String   @map("skill_id") @db.VarChar(191)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("skill_stars")
}

model SkillLike {
  id        String   @id @default(cuid()) @db.VarChar(191)
  userId    String   @map("user_id") @db.VarChar(191)
  skillId   String   @map("skill_id") @db.VarChar(191)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("skill_likes")
}

enum ApiClientStatus {
  ACTIVE
  REVOKED
}

model ApiClient {
  id          String          @id @default(cuid()) @db.VarChar(191)
  ownerId     String          @map("owner_id") @db.VarChar(191)
  name        String          @db.VarChar(64)
  keyPrefix   String          @map("key_prefix") @db.VarChar(16)
  apiKeyHash  String          @map("api_key_hash") @db.VarChar(64)
  status      ApiClientStatus @default(ACTIVE)
  lastUsedAt  DateTime?       @map("last_used_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  owner       User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  usageLogs   SkillUsageLog[]

  @@index([ownerId])
  @@index([apiKeyHash])
  @@map("api_clients")
}

model SkillUsageLog {
  id          String     @id @default(cuid()) @db.VarChar(191)
  skillId     String?    @map("skill_id") @db.VarChar(191)
  apiClientId String     @map("api_client_id") @db.VarChar(191)
  action      String     @db.VarChar(64)
  requestIp   String?    @map("request_ip") @db.VarChar(45)
  createdAt   DateTime   @default(now()) @map("created_at")
  apiClient   ApiClient  @relation(fields: [apiClientId], references: [id], onDelete: Cascade)

  @@index([apiClientId, createdAt])
  @@index([skillId])
  @@map("skill_usage_logs")
}
