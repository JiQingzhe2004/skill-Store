generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum EmailCodePurpose {
  REGISTER
  RESET_PASSWORD
}

model User {
  id              String      @id @default(cuid()) @db.VarChar(191)
  email           String      @unique @db.VarChar(191)
  username        String      @db.VarChar(32)
  passwordHash    String      @map("password_hash") @db.VarChar(255)
  isEmailVerified Boolean     @default(false) @map("is_email_verified")
  role            UserRole    @default(USER)
  avatar          String?     @db.LongText
  bio             String?     @db.VarChar(200)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  lastLoginAt     DateTime?   @map("last_login_at")
  emailCodes      EmailCode[]
  skills          Skill[]
  installedSkills UserInstalledSkill[]
  stars           SkillStar[]
  likes           SkillLike[]

  @@map("users")
}

enum SkillVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum SkillStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
  REJECTED
}

model Skill {
  id             String          @id @default(cuid()) @db.VarChar(191)
  slug           String          @unique @db.VarChar(128)
  name           String          @db.VarChar(128)
  description    String          @db.VarChar(512)
  tags           String          @default("") @db.VarChar(512)
  visibility     SkillVisibility @default(PUBLIC)
  status         SkillStatus     @default(DRAFT)
  latestVersion  String?         @map("latest_version") @db.VarChar(32)
  downloadCount  Int             @default(0) @map("download_count")
  starCount      Int             @default(0) @map("star_count")
  likeCount      Int             @default(0) @map("like_count")
  authorId       String          @map("author_id") @db.VarChar(191)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions       SkillVersion[]
  installs       UserInstalledSkill[]
  stars          SkillStar[]
  likes          SkillLike[]

  @@index([authorId])
  @@index([status, visibility])
  @@map("skills")
}

model SkillVersion {
  id          String   @id @default(cuid()) @db.VarChar(191)
  skillId     String   @map("skill_id") @db.VarChar(191)
  version     String   @db.VarChar(32)
  content     String   @db.LongText
  changelog   String?  @db.Text
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  skill       Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  installs    UserInstalledSkill[]

  @@unique([skillId, version])
  @@index([skillId])
  @@map("skill_versions")
}

model UserInstalledSkill {
  id               String       @id @default(cuid()) @db.VarChar(191)
  userId           String       @map("user_id") @db.VarChar(191)
  skillId          String       @map("skill_id") @db.VarChar(191)
  installedVersion String       @map("installed_version") @db.VarChar(32)
  trackLatest      Boolean      @default(true) @map("track_latest")
  installedAt      DateTime     @default(now()) @map("installed_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill            Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  versionRef       SkillVersion @relation(fields: [skillId, installedVersion], references: [skillId, version])

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@map("user_installed_skills")
}

model SkillStar {
  id        String   @id @default(cuid()) @db.VarChar(191)
  userId    String   @map("user_id") @db.VarChar(191)
  skillId   String   @map("skill_id") @db.VarChar(191)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("skill_stars")
}

model SkillLike {
  id        String   @id @default(cuid()) @db.VarChar(191)
  userId    String   @map("user_id") @db.VarChar(191)
  skillId   String   @map("skill_id") @db.VarChar(191)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("skill_likes")
}

model EmailCode {
  id        String           @id @default(cuid()) @db.VarChar(191)
  userId    String           @map("user_id") @db.VarChar(191)
  purpose   EmailCodePurpose
  code      String           @db.VarChar(6)
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, createdAt])
  @@map("email_codes")
}
