{
  "name": "skill-store",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c green,blue \"pnpm --filter @skill-store/web dev\" \"pnpm --filter @skill-store/api dev\"",
    "dev:web": "pnpm --filter @skill-store/web dev",
    "dev:api": "pnpm --filter @skill-store/api dev",
    "build": "pnpm --filter @skill-store/api build && pnpm --filter @skill-store/web build",
    "build:web": "pnpm --filter @skill-store/web build",
    "build:api": "pnpm --filter @skill-store/api build",
    "start:web": "pnpm --filter @skill-store/web start",
    "start:api": "pnpm --filter @skill-store/api start",
    "start": "concurrently -n web,api -c green,blue \"pnpm start:web\" \"pnpm start:api\"",
    "prisma:generate": "pnpm --filter @skill-store/api prisma:generate",
    "prisma:migrate:dev": "pnpm --filter @skill-store/api prisma:migrate:dev",
    "prisma:migrate:deploy": "pnpm --filter @skill-store/api prisma:migrate:deploy",
    "admin:promote": "node scripts/promote-admin.mjs",
    "release": "node scripts/package.mjs",
    "release:fast": "node scripts/package.mjs --no-build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "shadcn": "^4.0.8",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8"
  }
}
