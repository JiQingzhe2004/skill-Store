# 仅用于本地开发，生产环境通过 /setup 向导写入 apps/api/data/runtime.json
APP_URL=http://localhost:3000

DATABASE_URL=mysql://skill_store:skill_store@localhost:3306/skill_store
SHADOW_DATABASE_URL=mysql://skill_store:skill_store@localhost:3306/skill_store_shadow

JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# 首位管理员设置密钥（前端 /setup-admin 用），生产请改成随机串
ADMIN_SETUP_SECRET=change-me-in-production

# 邮件 SMTP（注册验证码 / 忘记密码）
# 本地开发可以用 Mailpit / MailHog：host=localhost port=1025（无需账号）
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Skill Store <no-reply@skill-store.local>
