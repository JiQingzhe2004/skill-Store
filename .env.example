APP_URL=http://localhost:3000

# 本地直连 MySQL（pnpm db:up / docker:dev 默认映射 13306，避免 Windows 3306 冲突）
DATABASE_URL=mysql://skill_store:skill_store@localhost:13306/skill_store
SHADOW_DATABASE_URL=mysql://skill_store:skill_store@localhost:13306/skill_store_shadow

# Docker 开发模式宿主机端口（pnpm docker:dev）
# Windows Hyper-V 常保留 3084-3183、3244-3343 等段，默认用 4520/4521
# DOCKER_WEB_PORT=4520
# DOCKER_API_PORT=4521
# DOCKER_MYSQL_PORT=13306

JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Skill Store <no-reply@skill-store.local>
